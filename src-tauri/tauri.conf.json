{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MemorySnatcher",
  "version": "0.9.8",
  "identifier": "de.pro-grammer.memorysnatcher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MemorySnatcher",
        "width": 1300,
        "height": 800
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": [
            "$APPDATA/**",
            "$APPDATA/.raw_cache/**",
            "$APPDATA/.raw_cache/.thumbnails/**"
          ],
          "requireLiteralLeadingDot": false
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "fs": {
      "scope": [
        "$DOWNLOAD/**",
        "$PICTURE/**"
      ]
    }
  }
}
